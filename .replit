modules = ["nodejs-20", "python-3.11"]
[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AI Scheduler"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Train Model"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Data Pipeline"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd statwise && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "AI Scheduler"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && python3 ai/scheduler.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Train Model"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && python3 -u ai/retrain.py --force"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Data Pipeline"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash ai/run_pipeline.sh"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[nix]
channel = "stable-25_05"
packages = ["glibcLocales", "libjpeg_turbo", "libpng", "libxcrypt", "ocl-icd", "opencl-headers", "pkg-config", "which", "xsimd"]

[userenv]

[userenv.shared]
FOOTBALL_API_TOKEN = "32bde0ee8c4146b783b331e4c677cbfd"
