# Copy this file to .env and fill in your values
# Never commit .env to version control

# football-data.org API key (free tier at football-data.org)
FOOTBALL_API_TOKEN=your_football_data_org_key_here

# API-Football via RapidAPI (optional, for extra league coverage)
X_RAPIDAPI_KEY=

# Supabase service role key (optional, bypasses Row Level Security)
# Get it from: Supabase dashboard > Settings > API > service_role key
SUPABASE_SERVICE_KEY=

# Override Supabase URL (optional – defaults to the hardcoded project URL)
SUPABASE_URL=
